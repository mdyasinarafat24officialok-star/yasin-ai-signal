                prediction = random.uniform(1.40, 2.50)
            
            res = round(prediction, 2)
            
        st.subheader("🎯 পরবর্তী সম্ভাব্য সিগন্যাল")
        st.markdown(f"<h1 style='color: #00ff00; text-align: center;'>{res}x</h1>", unsafe_allow_html=True)
        st.info(f"💡 টিপস: নিরাপদ থাকতে {round(res-0.10, 2)}x এ ক্যাশআউট করুন।")

