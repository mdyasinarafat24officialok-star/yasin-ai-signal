else:
    # মূল অ্যাপের নাম এখন "Crash Game Signal"
    st.title("🚀 Crash Game Signal")
    st.write(f"**Connected ID:** `{GAME_ID}`")
    
    st.markdown("---")
    
    # ইনপুট সেকশন
    st.subheader("📊 আগের রাউন্ডের রেজাল্ট দিন")
    col1, col2 = st.columns(2)
    with col1:
        last_val = st.number_input("Last Round (উদা: 1.50)", min_value=1.0, step=0.01)
    with col2:
        prev_val = st.number_input("Previous Round (উদা: 2.10)", min_value=1.0, step=0.01)

    if st.button("Analyze & Predict"):
        with st.spinner('আপনার আইডির প্যাটার্ন বিশ্লেষণ করা হচ্ছে...'):
            time.sleep(1.5)
            
            # আপনার স্ক্রিনশটের প্যাটার্ন অনুযায়ী অ্যালগরিদম
            if last_val < 1.40 and prev_val < 1.40:
                prediction = random.uniform(2.00, 3.80)
            elif last_val > 4.0:
                prediction = random.uniform(1.10, 1.35)
